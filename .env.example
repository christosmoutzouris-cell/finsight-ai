# FinSight AI — Environment Variables
# Αντέγραψε αυτό το αρχείο σε .env και συμπλήρωσε τα credentials
# ΜΗΝ ανεβάσεις το .env στο git!
#
# Τρέξε: ./setup_env.sh (Mac/Linux) ή .\setup_env.ps1 (Windows)
# για να δημιουργήσεις αυτόματα το .env με prompt για password

POSTGRES_USER=finsight
POSTGRES_PASSWORD=YOUR_PASSWORD_HERE
POSTGRES_DB=finsight_db
POSTGRES_PORT=5432

KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=stock_prices

SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA,TSLA
POLL_INTERVAL_SECONDS=10

# Docker socket path:
# Windows: //./pipe/dockerDesktopLinuxEngine
# Mac/Linux: /var/run/docker.sock
DOCKER_SOCK=/var/run/docker.sock